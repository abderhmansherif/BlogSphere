@inject NavigationManager NavManager
@rendermode InteractiveServer

<nav class="navbar">
    <div class="navbar-container">

        <!-- Brand -->
        <div class="navbar-brand" @onclick="OnNavigate">
            <svg class="logo-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" />
            </svg>
            <span class="logo-text">BlogSphere</span>
        </div>

        <!-- Mobile menu button -->
        <button class="mobile-menu-button" @onclick="ToggleMobileMenu">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M3 12h18M3 6h18M3 18h18" />
            </svg>
        </button>

        <div class="navbar-menu @(ShowMobileMenu ? "navbar-menu-mobile-open" : "")">

            <!-- Links -->
            <div class="navbar-links">
                <a @onclick="OnNavigate">Home</a>

                @if (IsAuthenticated) // Is Authenticated
                {
                    <a @onclick="NavigateToWrite">Write</a>
                    <a @onclick="@(() => NavManager.NavigateTo("#"))">Drafts</a>
                }
            </div>

            <!-- Actions -->
            <div class="navbar-actions">

                <!-- Search -->
                <div class="search-container">
                    <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="11" cy="11" r="8" />
                        <path d="m21 21-4.35-4.35" />
                    </svg>
                    <input type="text" placeholder="Search..." class="search-input" />
                </div>

                @if (IsAuthenticated) //Is Authenticated
                {
                    <!-- Notifications -->
                    <div class="notification-container">
                        <button class="icon-button" @onclick="ToggleNotifications">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                                <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                            </svg>
                            <span class="notification-badge">3</span>
                        </button>

                        @if (ShowNotifications)
                        {
                            <div class="dropdown-menu">
                                <div class="dropdown-header">
                                    <h4>Notifications</h4>
                                </div>

                                <div class="notification-item">
                                    <div class="notification-content">
                                        <p><strong>John Doe</strong> liked your article</p>
                                        <span class="notification-time">2 hours ago</span>
                                    </div>
                                </div>

                                <div class="notification-item">
                                    <div class="notification-content">
                                        <p><strong>Jane Smith</strong> started following you</p>
                                        <span class="notification-time">5 hours ago</span>
                                    </div>
                                </div>

                                <div class="notification-item">
                                    <div class="notification-content">
                                        <p><strong>Mike Johnson</strong> commented on your post</p>
                                        <span class="notification-time">1 day ago</span>
                                    </div>
                                </div>

                                <div class="dropdown-footer">
                                    <a @onclick="AllNotifications">
                                        View all notifications
                                    </a>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- User menu -->
                    <div class="user-menu-container">
                        <button class="user-avatar" @onclick="ToggleUserMenu">
                            <div class="avatar">
                                @(CurrentUser?.Name?.FirstOrDefault() ?? 'U')
                            </div>
                        </button>

                        @if (ShowUserMenu)
                        {
                            <div class="dropdown-menu dropdown-menu-right">
                                <div class="dropdown-header">
                                    <p><strong>@(CurrentUser?.Name ?? "User")</strong></p>
                                    <p class="user-email">@(CurrentUser?.Email ?? "user@example.com")</p>
                                </div>

                                <div class="dropdown-divider"></div>

                                <a class="dropdown-item" @onclick="@(() => NavManager.NavigateTo("#"))">Profile</a>
                                <a class="dropdown-item" @onclick="@(() => NavManager.NavigateTo("#"))">My Drafts</a>
                                <a class="dropdown-item" @onclick="@(() => NavManager.NavigateTo("#"))">Settings</a>

                                @if ((CurrentUser?.IsAdmin ?? false)) @*Is Admin*@
                                {
                                    <div class="dropdown-divider"></div>
                                    <a class="dropdown-item" @onclick="@(() => NavManager.NavigateTo("#"))">
                                        Admin Dashboard
                                    </a>
                                }

                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" @onclick="LogOut">
                                    Sign out
                                </a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="auth-buttons">
                        <Button Variant="ButtonVariant.Ghost" OnClick="@(() => NavManager.NavigateTo("/login"))">
                            <ChildContent>
                                Sign in
                            </ChildContent>
                        </Button>

                        <Button Variant="ButtonVariant.Primary" OnClick="@(() => NavManager.NavigateTo("/get-started"))">
                            <ChildContent>
                                Get started
                            </ChildContent>
                        </Button>
                    </div>
                }
            </div>
        </div>
    </div>
</nav>


@code
{
    [Parameter]
    public UserDto? CurrentUser { get; set; }
    [Parameter]
    public bool IsAuthenticated { get; set; } = false;

    protected bool ShowNotifications { get; set; } = false;
    protected bool ShowUserMenu { get; set; }  = false;
    protected bool ShowMobileMenu { get; set; }

    protected void ToggleNotifications()
    {
        ShowNotifications = !ShowNotifications;
        ShowUserMenu = false;
    }

    protected void ToggleUserMenu()
    {
        ShowUserMenu = !ShowUserMenu;
        ShowNotifications = false;
    }

    protected void ToggleMobileMenu()
    {
        ShowMobileMenu = !ShowMobileMenu;
    }

    public void OnNavigate()
    {
        NavManager.NavigateTo("/");
    }

    public void NavigateToWrite()
    {
        NavManager.NavigateTo("write");
    }

    public void AllNotifications()
    {
        NavManager.NavigateTo("notifications");
    }

    public void LogOut()
    {
        CurrentUser = new();

    }


    public class UserDto
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public bool IsAdmin { get; set; } = false;
    }

}
