@* @page "/forgot-password"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Web
@rendermode InteractiveServer
@inject NavigationManager NavManager

<div class="auth-page">
    <div class="auth-container">
        <div class="auth-card">

            @if (submitted)
            {
                <div class="success-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                        <polyline points="22 4 12 14.01 9 11.01" />
                    </svg>
                </div>
                <div class="auth-header">
                    <h1>Check your email</h1>
                    <p>
                        We've sent a password reset link to <strong>@forgotPasswordDto.Email</strong>
                    </p>
                </div>
                <div class="auth-actions">
                    <Button Variant="ButtonVariant.Primary" Size="Size.lg" FullWidth="true" @onclick="@(() => NavManager.NavigateTo("/login"))">
                        Back to sign in
                    </Button>
                    <p class="reset-info">
                        Didn't receive the email? Check your spam folder or
                        <a @onclick="() => submitted = false" class="link">try again</a>
                    </p>
                </div>
            }
            else
            {
                <div class="auth-header">
                    <h1>Reset your password</h1>
                    <p>Enter your email address and we'll send you a link to reset your password</p>
                </div>

                <form @onsubmit="HandleSubmit" @onsubmit:preventDefault="true" class="auth-form">
                   
                        <AppInput Label="Email address"
                                  InputType="InputType.Email"
                                  Placeholder="Enter your email"
                                  Error="@error"
                                  OnChange="OnEmailChange">
                            <Icon>
                                <svg viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' width='18' height='18'>
                                    <rect x='2' y='4' width='20' height='16' rx='2' />
                                    <path d='m2 7 10 7 10-7' />
                                </svg>
                            </Icon>
                        </AppInput>

                    <Button Type="ButtonType.Submit"
                            Variant="ButtonVariant.Primary"
                            Size="Size.lg"
                            FullWidth="true">
                        Send reset link
                    </Button>
                </form>

                <div class="auth-footer">
                    <p>
                        Remember your password?
                        <a @onclick="@(() => NavManager.NavigateTo("/login"))" class="link">Sign in</a>
                    </p>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private bool submitted = false;
    private string error = string.Empty;

    private ForgotPasswordDto forgotPasswordDto = new();

    private void HandleSubmit(EventArgs e)
    {
        error = "";

        if (string.IsNullOrWhiteSpace(forgotPasswordDto.Email))
        {
            error = "Email is required";
            return;
        }

        if (!forgotPasswordDto.Email.Contains("@"))
        {
            error = "Enter a valid email address";
            return;
        }

        // Mock password reset
        submitted = true;
    }

    private void OnEmailChange(string value)
    {
        forgotPasswordDto.Email = value;
        error = ""; // Reset error on change
    }

    public class ForgotPasswordDto
    {
        public string Email { get; set; } = string.Empty;
    }
} *@
